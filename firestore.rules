rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function allowedUserKeys() {
      return ['username', 'email', 'name', 'role', 'avatar', 'phone', 'createdAt', 'updatedAt'];
    }

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userProfilePath() {
      return /databases/$(database)/documents/appUsers/$(request.auth.uid);
    }

    function userProfileExists() {
      return signedIn() && exists(userProfilePath());
    }

    function isAdmin() {
      return userProfileExists() && get(userProfilePath()).data.role == 'admin';
    }

    function validRole(role) {
      return role in ['admin', 'officer', 'general'];
    }

    function validSelfRegistrationRole(role) {
      return role == 'general';
    }

    function validUserDocumentShape() {
      return request.resource.data.keys().hasOnly(allowedUserKeys())
        && request.resource.data.email is string
        && request.resource.data.username is string
        && request.resource.data.name is string
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && validRole(request.resource.data.role);
    }

    function sameIdentityAsAuth() {
      return request.auth.token.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.username == request.auth.token.email;
    }

    function immutableIdentityFields() {
      return request.resource.data.email == resource.data.email
        && request.resource.data.username == resource.data.username
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /appUsers/{userId} {
      allow create: if signedIn()
        && validUserDocumentShape()
        && (
          (
            isOwner(userId)
            && validSelfRegistrationRole(request.resource.data.role)
            && sameIdentityAsAuth()
          )
          || isAdmin()
        );

      allow get: if signedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();

      allow update: if signedIn()
        && validUserDocumentShape()
        && immutableIdentityFields()
        && (
          isAdmin()
          || (
            isOwner(userId)
            && request.resource.data.role == resource.data.role
            && request.resource.data.email == resource.data.email
            && request.resource.data.username == resource.data.username
          )
        );

      allow delete: if isAdmin() || isOwner(userId);
    }
  }
}
